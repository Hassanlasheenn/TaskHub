SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (optional). Local: use redis://localhost:6379/0. Production (Railway): set REDIS_URL in Railway Variables to your Redis URL (e.g. from Redis service → Connect; use redis.railway.internal only on Railway).
REDIS_URL=redis://localhost:6379/0
